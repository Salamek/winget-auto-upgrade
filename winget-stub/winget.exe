#!/usr/bin/env python

import sys
import os
from pathlib import Path

class Winget:

    def __init__(self):
        self.pwd = Path(__file__).parent

    def upgrade(self, name: str | None) -> bytes:
        if not name:
            with self.pwd.joinpath('w-upgrade.txt').open('rb') as f:
                return f.read()
        with self.pwd.joinpath('w-upgrade-p.txt').open('rb') as f:
            return f.read()

    def list(self, _) -> bytes:
        with self.pwd.joinpath('w-list.txt').open('rb') as f:
            return f.read()


if __name__ == '__main__':
    winget = Winget()

    command_name = sys.argv[1] if len(sys.argv) > 1 else None
    if not command_name:
        print('Error: Provide command')
        sys.exit(1)

    command = getattr(winget, command_name)

    if not command:
        print('Error: Unknown command')
        sys.exit(1)

    data = command(sys.argv[2] if len(sys.argv) > 2 else None)
    os.write(1, data)
    sys.exit(0)
